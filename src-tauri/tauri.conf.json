{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lightsee",
  "version": "0.8.5",
  "identifier": "com.yonggill.lightsee",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Lightsee",
        "width": 900,
        "height": 700,
        "minWidth": 400,
        "minHeight": 300
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["md", "markdown", "mdown", "mkd", "mdwn"],
        "mimeType": "text/markdown",
        "description": "Markdown Document",
        "role": "Viewer"
      }
    ],
    "macOS": {
      "signingIdentity": "Developer ID Application: Wishket Co., Ltd. (N9TVH7WV9T)"
    }
  },
  "plugins": {
    "cli": {
      "description": "Lightsee - Markdown viewer and cloud sharing tool",
      "args": [],
      "subcommands": {
        "expose": {
          "description": "Expose a file or folder to the cloud",
          "args": [
            {
              "name": "path",
              "description": "Path to markdown file or folder",
              "index": 1,
              "required": true,
              "takesValue": true
            }
          ]
        },
        "list": {
          "description": "List cloud shares",
          "args": []
        },
        "remove": {
          "description": "Remove a cloud share",
          "args": [
            {
              "name": "slug",
              "description": "Share slug to remove",
              "index": 1,
              "required": true,
              "takesValue": true
            }
          ]
        }
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENCM0Y1RENGMzc3QkVCMQpSV1N4dm5mejNQV3pETm4reU5nWFZsREJ1OGJzWThIdHJsdFA2MTVsaTJNMlpEak1xQm9Rakk5Kwo=",
      "endpoints": [
        "https://github.com/wishket-aidp/lightsee/releases/latest/download/latest.json"
      ]
    }
  }
}
