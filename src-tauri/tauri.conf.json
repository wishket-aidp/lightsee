{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lightsee",
  "version": "0.4.4",
  "identifier": "com.yonggill.lightsee",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Lightsee",
        "width": 900,
        "height": 700,
        "minWidth": 400,
        "minHeight": 300
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["md", "markdown", "mdown", "mkd", "mdwn"],
        "mimeType": "text/markdown",
        "description": "Markdown Document",
        "role": "Viewer"
      }
    ],
    "macOS": {
      "signingIdentity": "Developer ID Application: Wishket Co., Ltd. (N9TVH7WV9T)"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENCM0Y1RENGMzc3QkVCMQpSV1N4dm5mejNQV3pETm4reU5nWFZsREJ1OGJzWThIdHJsdFA2MTVsaTJNMlpEak1xQm9Rakk5Kwo=",
      "endpoints": [
        "https://github.com/wishket-aidp/lightsee/releases/latest/download/latest.json"
      ]
    }
  }
}
